{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/*.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/api/ingredients", "destination": "/api/ingredients" },
    { "source": "/api/recipes", "destination": "/api/recipes" },
    { "source": "/api/favorites", "destination": "/api/favorites" },
    { "source": "/api/meal-plan", "destination": "/api/meal-plan" }
  ]
}
