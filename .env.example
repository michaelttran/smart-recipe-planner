# Server-side only (Expo API routes — never exposed to client)
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Settings → API → service_role

# Client-side (safe to expose — anon key, not service key)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key  # Settings → API → anon / public

# Production only (unused in local dev)
EXPO_PUBLIC_API_URL=https://your-deployed-server.com
